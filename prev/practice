// pascal triangle
class Solution {
    public List<List<Integer>> generate(int numRows) {
        List<List<Integer>> t=new ArrayList<>();
        List<Integer> frow=new ArrayList<>();
        frow.add(1);
        t.add(frow);
        for(int i=1;i<numsRow.length;i++){
            List<Integer> prev=new ArrayList<>(i-1);
            List<Intger> curr=new ArrayList<>();
            curr.add(1);
            for(int j=1;j<numsRow.length;j++){
                curr.add(prev.get(j-1)+prev.get(j));
