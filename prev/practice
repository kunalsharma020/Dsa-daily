// rev int
class Solution {
    public int reverse(int x) {
        long rev=0;
        while(x!=0){
            int lastDigit=x%10;
            rev=rev*10+lastDigit;
            x /=10;
        }
        if(x>Integer.MAX_VALUE || x<Integer.MIN_VALUE){
            return 0
        }
        return (int)rev;
    }
}
