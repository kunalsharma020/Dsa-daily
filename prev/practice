// most contained water
class Solution {
    public int maxArea(int[] height) {
        int l=0,r=height.length;
        int maxW=0;

        while(l<r){
            int w=r-l;
            int h=Math.min(height[l],height[r]);
            maxW=Math.max(maxW, w*h);

            if(height[l]<height[r]){
                l++;
            }else{
                r--;
            }
        }
        return maxW;
    }
}
